# Cloudinary — required for media + concat URLs.
# Cloud name lives on your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=

# Unsigned upload preset (Cloudinary → Settings → Upload).
VITE_CLOUDINARY_UPLOAD_PRESET=sceneos_unsigned

# Auth0 (Single Page Application).
# Get these from your Auth0 dashboard → Applications → SceneOS.
# Put real values in `.env.local` (gitignored), not here.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# Backend API base URL (optional in local dev).
# **Leave unset in dev** so requests use same-origin `/api` and Vite’s proxy to :8787.
# If you set VITE_API_BASE_URL to http://localhost:8787 (or 127.0.0.1) you must
# open the app in the *same* hostname, and set backend ALLOWED_ORIGIN to that origin.
# Production: e.g. https://api.sceneos.us
# VITE_API_BASE_URL=
