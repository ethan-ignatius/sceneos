# Cloudinary — required for media + concat URLs.
# Cloud name lives on your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=

# Unsigned upload preset (Cloudinary → Settings → Upload).
VITE_CLOUDINARY_UPLOAD_PRESET=sceneos_unsigned

# Backend API base URL.
# Local dev:    http://localhost:8787
# Production:   https://api.sceneos.us  (or wherever FastAPI is deployed)
# The deployed backend's CORS allow-list (ALLOWED_ORIGIN) must include
# the frontend origin or fetches will fail with a CORS error.
VITE_API_BASE_URL=http://localhost:8787
