# Cloudinary — required for media + concat URLs
# Get cloud_name from your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=

# Unsigned upload preset (create one in Cloudinary → Settings → Upload)
VITE_CLOUDINARY_UPLOAD_PRESET=sceneos_unsigned

# Backend API base URL. Defaults to the local FastAPI dev server.
# In production, point this at your deployed backend (e.g. https://api.sceneos.us).
# The Tier 3 mock layer was deprecated; real backend creds are now required.
VITE_API_BASE_URL=http://localhost:8787
