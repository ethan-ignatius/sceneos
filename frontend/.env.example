# Cloudinary — required for media + concat URLs
# Get cloud_name from your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=

# Unsigned upload preset (create one in Cloudinary → Settings → Upload)
VITE_CLOUDINARY_UPLOAD_PRESET=sceneos_unsigned

# Backend API base URL (Hono server). Local default below.
VITE_API_BASE_URL=http://localhost:8787
