# SceneOS backend env
PORT=8787

# Cloudinary (server-side signing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Higgsfield (primary video gen) — leave blank to run with the mock provider
HIGGSFIELD_API_KEY=
HIGGSFIELD_BASE_URL=https://cloud.higgsfield.ai

# Fallback providers (optional but recommended for hackathon resilience)
SEGMIND_API_KEY=
REPLICATE_API_TOKEN=

# Mock-provider tuning (used when HIGGSFIELD_API_KEY is unset)
# Simulated generation latency in ms. Drop to 3000 for fast smoke tests.
MOCK_GENERATION_LATENCY_MS=12000

# Optional: reference image URL passed as start_image_url for image-to-video
# providers. Mock ignores it; Higgsfield uses it once wired.
TEST_REFERENCE_IMAGE_URL=

# Agent LLM
OPENAI_API_KEY=
# or set ANTHROPIC_API_KEY and switch services/agent.ts to use it

# CutOS handoff target — base URL of the running CutOS instance
CUTOS_BASE_URL=http://localhost:3000
CUTOS_API_TOKEN=

# CORS
ALLOWED_ORIGIN=http://localhost:5173
