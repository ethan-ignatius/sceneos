# SceneOS backend env
PORT=8787

# ──────────────────────────────────────────────────────────────────────
# MOCK MODE — frontend devs run with this on so the app is end-to-end
# functional without any keys. Set to `false` for real provider calls.
#
# Auto-default:
#   If unset, the backend auto-detects: any required key missing → mock.
#   With a full set of keys (Higgsfield/Kling + OpenAI + Cloudinary) → real.
#
# Explicit override:
#   MOCK_MODE=true   → always mock, regardless of keys
#   MOCK_MODE=false  → always real (will 501 if a service is unimplemented)
# ──────────────────────────────────────────────────────────────────────
# MOCK_MODE=true

# ──────────────────────────────────────────────────────────────────────
# Generation provider — switch the live engine without touching code.
#
#   higgsfield  Recorded-demo tier.  Best visual quality (Sora 2 / Veo 3.1
#               via Higgsfield routing). Slow: 60–180s per clip. Use this
#               while we record the demo video.
#   kling       Live-demo tier. Direct Kling 3.0 API. ~15–30s per clip,
#               quality slightly below Sora/Veo. Cloudinary color-grade
#               brings it back to parity with the recorded video tier.
#   replicate   Multi-model fallback. Use if Higgsfield AND Kling are down.
#   cached      Hard-coded demo project. Instant. Reads pre-rendered
#               Cloudinary public_ids from services/cached-demo.ts. The
#               final on-stage safety net — flip to this if anything else
#               flakes the morning of the demo.
#
# Default is `higgsfield`. For Sunday's live demo prefer `kling`. Keep
# `cached` ready as the third tier (see HACKATHON_STRATEGY §5).
# ──────────────────────────────────────────────────────────────────────
GENERATION_PROVIDER=higgsfield

# Higgsfield (primary, recorded-demo tier)
HIGGSFIELD_API_KEY=
HIGGSFIELD_BASE_URL=https://cloud.higgsfield.ai

# Kling (live-demo tier — direct, faster than going through Higgsfield)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api-singapore.klingai.com

# Replicate (multi-model fallback)
REPLICATE_API_TOKEN=

# Cloudinary (server-side signing + final URL construction)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Agent LLM
OPENAI_API_KEY=
# or set ANTHROPIC_API_KEY and switch services/agent.ts to use it

# CutOS handoff target — base URL of the running CutOS instance
CUTOS_BASE_URL=http://localhost:3000
CUTOS_API_TOKEN=

# CORS
ALLOWED_ORIGIN=http://localhost:5173
