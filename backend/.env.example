# SceneOS backend env
PORT=8787

# Cloudinary (server-side signing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Higgsfield (primary video gen)
HIGGSFIELD_API_KEY=
HIGGSFIELD_BASE_URL=https://cloud.higgsfield.ai

# Fallback providers (optional but recommended for hackathon resilience)
SEGMIND_API_KEY=
REPLICATE_API_TOKEN=

# Agent LLM
OPENAI_API_KEY=
# or set ANTHROPIC_API_KEY and switch services/agent.ts to use it

# CutOS handoff target — base URL of the running CutOS instance
CUTOS_BASE_URL=http://localhost:3000
CUTOS_API_TOKEN=

# CORS
ALLOWED_ORIGIN=http://localhost:5173
