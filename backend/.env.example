# SceneOS backend env
PORT=8787

# ──────────────────────────────────────────────────────────────────────
# MOCK MODE — frontend devs run with this on so the app is end-to-end
# functional without any keys. Set to `false` for real provider calls.
#
# Auto-default:
#   If unset, the backend auto-detects: any required key missing → mock.
#   With a full set of keys (Higgsfield/Kling + Anthropic + Cloudinary) → real.
#
# Explicit override:
#   MOCK_MODE=true   → always mock, regardless of keys
#   MOCK_MODE=false  → always real
# ──────────────────────────────────────────────────────────────────────
# MOCK_MODE=true

# ──────────────────────────────────────────────────────────────────────
# Generation provider — switch the live engine without touching code.
#
#   higgsfield  Recorded-demo tier. Two-stage T2I→I2V via Higgsfield.
#   kling       Live-demo tier. Direct Kling API.
#   replicate   Multi-model fallback.
#   cached      Hard-coded demo project. Instant safety net.
# ──────────────────────────────────────────────────────────────────────
GENERATION_PROVIDER=higgsfield

# Higgsfield (primary video gen)
# Auth header is `Authorization: Key {API_KEY}:{API_SECRET}`
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
HIGGSFIELD_BASE_URL=https://platform.higgsfield.ai

# Kling (live-demo tier — direct, faster than going through Higgsfield)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api-singapore.klingai.com

# Replicate (multi-model fallback)
REPLICATE_API_TOKEN=

# Cloudinary (server-side signing + final URL construction)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Agent LLM — Claude (Anthropic)
ANTHROPIC_API_KEY=
# Optional model overrides (default: claude-opus-4-7)
ANTHROPIC_AGENT_MODEL=
ANTHROPIC_DECOMPOSE_MODEL=

# CutOS handoff target — base URL of the running CutOS instance
CUTOS_BASE_URL=http://localhost:3000
CUTOS_API_TOKEN=

# CORS
ALLOWED_ORIGIN=http://localhost:5173
