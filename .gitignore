examples/
issues/
.claude/
examples-locked/
demo-plan/

# Service-account JSONs and any other secret material — repo-wide
# safety net so a stray *.json in any subfolder can't be committed
# without an explicit override.
.secrets/
*service-account*.json
*-sa-*.json

# Node / Vite
node_modules/
dist/
*.tsbuildinfo

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Env / secrets — keep .env.example tracked, ignore everything else
.env
.env.*
!.env.example
!**/.env.example

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
