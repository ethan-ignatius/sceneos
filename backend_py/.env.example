# SceneOS backend — environment template
# Copy to .env and fill in. Never commit .env.

# ── Vertex AI (REQUIRED — only LLM SceneOS uses) ────────────────────────────
# Vertex Gemini 2.5 powers the agent + decompose + editor.
# Vertex Veo 3 is the default video provider.
# Both share these credentials.
GOOGLE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_CLOUD_LOCATION=us-central1

# Optional model overrides (defaults below).
# GEMINI_AGENT_MODEL=gemini-2.5-flash
# GEMINI_DECOMPOSE_MODEL=gemini-2.5-pro

# ── Cloudinary (REQUIRED — media + fl_splice URL bake) ──────────────────────
# Either set CLOUDINARY_URL (preferred) OR the explicit triple.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Higgsfield (OPTIONAL — alternate video lane, runs in parallel with Vertex)
# Two supported auth shapes — the provider auto-detects:
#
#   Public API (higgsfieldapi.com):
#     HIGGSFIELD_API_KEY=<single bearer token>
#
#   Legacy platform (cloud.higgsfield.ai / platform.higgsfield.ai):
#     HIGGSFIELD_API_KEY=<UUID API key id>
#     HIGGSFIELD_API_SECRET=<64-hex API key secret>
#
# Setting BOTH key+secret routes to the legacy platform endpoint with
# `Authorization: Key {id}:{secret}`. Setting only the key uses the
# public bearer endpoint. Get a key at https://cloud.higgsfield.ai
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
# HIGGSFIELD_BASE_URL=                                    # optional override

# ── fal.ai (OPTIONAL — third video lane) ────────────────────────────────────
# Used when the user explicitly picks "fal" as the provider.
FAL_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins, or "*" for dev.
# Include BOTH localhost and 127.0.0.1 with the same port: they are different Origins
# in browsers, and Vite is often opened as either. Production: your deployed origin only.
ALLOWED_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Mode override ───────────────────────────────────────────────────────────
# By default the backend auto-detects: if Cloudinary + Vertex creds are
# present, real mode; otherwise mock mode. Override explicitly:
#   MOCK_MODE=true   → force mock (deterministic responses, no provider calls)
#   MOCK_MODE=false  → force real (will 502 if creds missing)
# MOCK_MODE=

# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Veo (optional — video generation tuning) ──────────────────────────────
# VEO_MODEL_ID=veo-3.1-fast-generate-001
# VEO_RESOLUTION=1080p
# VEO_GENERATE_AUDIO=true
# VEO_SPEED_MODE=fast
#   If set and VEO_RESOLUTION / VEO_GENERATE_AUDIO are unset: 720p + no Veo
#   native audio (often faster; use stitch / music for sound).
# VEO_POLL_INTERVAL_SECONDS=2
# VEO_PREFER_LONGER_ON_TIE=false
#   Duration snaps to 4/6/8s; on a tie, shorter is default for wall-clock.
